# =============================================
# Build Lab - Environment Variables
# =============================================
# Copy to .env.local and fill in values

# =============================================
# SUPABASE (Database)
# =============================================
# Create project at: supabase.com
# Find in: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
# Service role key (for admin operations, setup scripts)
# WARNING: Keep this secret! Never commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================
# GITHUB (Deploy Trigger)
# =============================================
# Create at: github.com/settings/tokens
# Scopes needed: repo, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
FACTORY_REPO=thebuildlabz/factory

# =============================================
# VERCEL (Hosting)
# =============================================
# Get at: vercel.com/account/tokens
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxx
# Get from: vercel.com → Settings → General
VERCEL_ORG_ID=team_xxxxxxxxxxxx

# =============================================
# RESEND (Email)
# =============================================
# Create at: resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Build Lab <hello@yourdomain.com>

# =============================================
# INTERNAL API
# =============================================
# Generate with: openssl rand -hex 32
STATUS_API_KEY=your-random-secret-key

# =============================================
# APP CONFIG
# =============================================
VITE_API_URL=https://your-buildlab-site.vercel.app

# =============================================
# QUICK SETUP STEPS
# =============================================
# 1. Create Supabase project, run SQL from database/schema.sql
# 2. Create GitHub token with repo + workflow scopes
# 3. Create Vercel token
# 4. Create Resend account, verify domain
# 5. Generate STATUS_API_KEY
# 6. Deploy to Vercel with these env vars
# 7. Add same vars to GitHub secrets (for factory repo)
